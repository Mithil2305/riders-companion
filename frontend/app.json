{
  "expo": {
    "name": "Rider's Companion",
    "slug": "riders-companion",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hero.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "riderscompanion",
    "splash": {
      "image": "./assets/images/hero.png",
      "resizeMode": "contain",
      "backgroundColor": "#e8e8e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.riderscompanion.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hero.png",
        "backgroundColor": "#e8e8e8"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "package": "com.riderscompanion.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/hero.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-location"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b49ab3f3-b4f3-4327-99ae-e699ae23a862"
      }
    }
  }
}
