{
  "expo": {
    "name": "Rider's Companion",
    "slug": "riders-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hero.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "riderscompanion",
    "splash": {
      "image": "./assets/images/hero.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.riderscompanion.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hero.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.riderscompanion.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/hero.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
